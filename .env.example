# ─── PayloadCMS ───────────────────────────────────
PAYLOAD_BASE_URL=https://api.example.com
PAYLOAD_API_KEY=your_api_key_here
PAYLOAD_PREVIEW_SECRET=your_payload_secret_here

# ─── Auther OAuth ─────────────────────────────────
AUTH_BASE_URL=https://auth.example.com
BLOG_CLIENT_ID=your-blog-client-id
# Use https://blog.example.com for production, http://localhost:3000 for dev
BLOG_REDIRECT_URI=http://localhost:3000/auth/callback
BLOG_POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# ─── Signup Trigger (server-only) ─────────────────
BLOG_SIGNUP_FLOW_SLUG=blog-commenter
BLOG_SIGNUP_AUTHORIZATION_SPACE_ID=your-payload-content-space-id
BLOG_SIGNUP_TRIGGER_KIND=oauth_client
BLOG_SIGNUP_TRIGGER_CLIENT_ID=your-blog-signup-trigger-client-id
BLOG_SIGNUP_TRIGGER_CLIENT_SECRET=your-server-only-trigger-secret
BLOG_SIGNUP_INTENT_TTL_SECONDS=300

# Copy this file to .dev.vars for local vinext dev (Cloudflare Workers format)
