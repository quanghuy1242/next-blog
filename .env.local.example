# PayloadCMS Configuration
# Copy this file to .env.local and fill in your actual values

# PayloadCMS Base URL (without /api/graphql)
# Example: https://your-payload-instance.com
PAYLOAD_BASE_URL=https://api.example.com

# PayloadCMS API Key
# Generate this in your PayloadCMS admin panel under Users > API Keys
PAYLOAD_API_KEY=your_api_key_here

# Auther blog OAuth client. R2 does not rename or rework these values.
AUTH_BASE_URL=https://auth.example.com
BLOG_CLIENT_ID=your-blog-client-id
BLOG_REDIRECT_URI=http://localhost:3000/auth/callback
BLOG_POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# Note: These environment variables are used server-side only
# Never expose your API key in client-side code
